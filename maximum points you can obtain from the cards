class Solution {
    public int maxScore(int[] cardPoints, int k) {
 int n = cardPoints.length;

        int lsum = 0;
        int rsum = 0;
        int maxScore = 0;

        // First take all k cards from left
        for (int i = 0; i < k; i++) {
            lsum += cardPoints[i];
        }

        maxScore = lsum;

        int rIndex = n - 1;

        // Remove one card from left and add one from right
        for (int i = k - 1; i >= 0; i--) {
            lsum -= cardPoints[i];
            rsum += cardPoints[rIndex];
            rIndex--;

            maxScore = Math.max(maxScore, lsum + rsum);
        }

        return maxScore;
    }
}


